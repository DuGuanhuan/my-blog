# Required: Notion integration secret.
# Create one in Notion → Settings → Connections → Develop or manage integrations.
NOTION_API_KEY=secret_xxx

# Required unless you keep the built-in default database id in src/lib/notion.ts.
NOTION_DATABASE_ID=301b5a28fc988125a53fc0781262e71c

# Optional: use Notion data source API path explicitly when needed.
# NOTION_DATA_SOURCE_ID=

# Optional: Music Room database used by the homepage album shelf.
# NOTION_ALBUMS_DATABASE_ID=58af1fdec3754d308b443520085fb822

# Optional build-time tuning for larger Notion databases/pages.
# NOTION_TIMEOUT_MS=60000
# NOTION_RETRY_TIMES=3
# NOTION_CHILD_CONCURRENCY=8
# NOTION_MAX_BLOCK_DEPTH=12
