---
import BookShelfRow from './BookShelfRow.astro';
import type { Book } from '../lib/notion';

interface Props {
  books: Book[];
}

const { books } = Astro.props;
if (!books?.length) return null;
---

<section class="now-reading" aria-labelledby="now-reading-title">
  <header class="now-reading__header">
    <div>
      <h2 id="now-reading-title">现在在读</h2>
      <p>Notes from the books currently on my desk.</p>
    </div>
    <a href="/about#bookshelf">查看书架 <span aria-hidden="true">→</span></a>
  </header>

  <BookShelfRow
    books={books.slice(0, 6)}
    label="现在在读"
    initialIndex={Math.floor(Math.min(books.length, 6) / 2)}
    compact
  />
</section>

<style>
  .now-reading {
    padding: 40px 0 34px;
    border-top: 1px solid var(--line);
  }

  .now-reading__header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .now-reading__header h2,
  .now-reading__header p {
    margin: 0;
  }

  .now-reading__header h2 {
    color: rgba(17, 17, 17, .78);
    font-family: var(--serif);
    font-size: clamp(20px, 2.5vw, 25px);
    font-weight: 500;
    letter-spacing: .03em;
  }

  .now-reading__header p {
    margin-top: 2px;
    color: rgba(17, 17, 17, .38);
    font-family: var(--sans);
    font-size: 11px;
  }

  .now-reading__header > a {
    margin-left: auto;
    color: rgba(17, 17, 17, .5);
    font-family: var(--sans);
    font-size: 12px;
    text-decoration: none;
  }

  .now-reading__header > a:hover {
    color: rgba(17, 17, 17, .88);
  }

  @media (max-width: 680px) {
    .now-reading__header p {
      display: none;
    }

    .now-reading__header > a {
      font-size: 11px;
    }
  }
</style>
