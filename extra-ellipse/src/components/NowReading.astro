---
import type { Book } from '../lib/notion';

interface Props {
  books: Book[];
}

const { books } = Astro.props;
if (!books || books.length === 0) return null;

function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}

// 与 Bookshelf 同步调色板
const palette: { spine: string; ink: string }[] = [
  { spine: '#d96e2c', ink: 'rgba(255,255,255,.95)' },
  { spine: '#1f3a52', ink: 'rgba(255,255,255,.95)' },
  { spine: '#1a1a1a', ink: 'rgba(255,255,255,.92)' },
  { spine: '#8c9070', ink: 'rgba(255,255,255,.95)' },
  { spine: '#5a3e2e', ink: 'rgba(255,255,255,.95)' },
  { spine: '#c89a14', ink: 'rgba(255,255,255,.95)' },
  { spine: '#5b2230', ink: 'rgba(255,255,255,.95)' },
  { spine: '#7a8a6f', ink: 'rgba(255,255,255,.95)' },
  { spine: '#5a6470', ink: 'rgba(255,255,255,.95)' },
  { spine: '#d4c5a3', ink: 'rgba(30,30,30,.78)' },
  { spine: '#ebe5d4', ink: 'rgba(30,30,30,.82)' },
  { spine: '#b95324', ink: 'rgba(255,255,255,.95)' },
];

function colorFor(b: Book) {
  return palette[hashStr(b.id + b.title) % palette.length];
}

function spineTitle(t: string, max = 18): string {
  return t.length <= max ? t : t.slice(0, max - 1) + '…';
}

function initials(b: Book): string {
  if (!b.author) return '';
  const cleaned = b.author.replace(/[《》()·•;，,.;:：]/g, ' ').trim();
  const cn = cleaned.match(/[\u4e00-\u9fa5]{1,3}/g);
  if (cn && cn.length) return cn[cn.length - 1].slice(0, 2);
  const en = cleaned.split(/\s+/).filter(Boolean);
  if (en.length >= 2) return (en[0][0] + en[en.length - 1][0]).toUpperCase();
  return cleaned.slice(0, 2).toUpperCase();
}
---

<section class="now-reading" aria-label="现在在读">
  <div class="nr-header">
    <div class="nr-number" aria-hidden="true">
      <span class="num">03</span>
      <span class="hatch"></span>
    </div>
    <h2 class="nr-title-h">现在在读</h2>
    <a href="/about#bookshelf" class="nr-more">查看书架 →</a>
  </div>

  <div class="nr-stage">
    <div class="nr-books" role="list">
      {books.map((b) => {
        const c = colorFor(b);
        const title = spineTitle(b.title, 16);
        const init = initials(b);
        return (
          <a class="nr-book" href={b.url || '/about#bookshelf'} role="listitem" title={`${b.title}${b.author ? ' — ' + b.author : ''}`} style={`--spine: ${c.spine}; --ink: ${c.ink};`}>
            <span class="nr-book-spine">
              <span class="nr-book-title">{title}</span>
              {init && <span class="nr-book-init">{init}</span>}
            </span>

            <span class="nr-book-card" aria-hidden="true">
              {b.cover ? (
                <img src={b.cover} alt={b.title} loading="lazy" />
              ) : (
                <span class="nr-card-placeholder" style={`background: linear-gradient(135deg, ${c.spine}, color-mix(in srgb, ${c.spine} 60%, #000))`}>
                  <span class="nr-card-title">{b.title}</span>
                  {b.author && <span class="nr-card-author">{b.author}</span>}
                </span>
              )}
              <span class="nr-card-meta">
                <span class="nr-card-name">{b.title}</span>
                {b.author && <span class="nr-card-author-line">{b.author}</span>}
                {b.keywords && <span class="nr-card-keywords">{b.keywords}</span>}
              </span>
            </span>
          </a>
        );
      })}
    </div>
    <div class="nr-board" aria-hidden="true"></div>
  </div>
</section>

<style>
  .now-reading {
    padding: 32px 0 28px;
    border-top: 1px solid var(--line);
  }

  .nr-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
  }

  .nr-number {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--serif);
  }
  .nr-number .num {
    font-size: 18px;
    font-weight: 700;
    color: rgba(17,17,17,.78);
    border: 1px solid rgba(17,17,17,.18);
    padding: 1px 9px;
    border-radius: 4px;
    background: rgba(255,255,255,.55);
  }
  .nr-number .hatch {
    display: inline-block;
    width: 18px;
    height: 14px;
    background-image:
      linear-gradient(135deg, transparent 33%, rgba(17,17,17,.18) 33%, rgba(17,17,17,.18) 38%, transparent 38%,
      transparent 60%, rgba(17,17,17,.18) 60%, rgba(17,17,17,.18) 65%, transparent 65%);
    border: 1px solid rgba(17,17,17,.18);
    border-radius: 3px;
  }

  .nr-title-h {
    margin: 0;
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 700;
    color: rgba(17,17,17,.92);
    letter-spacing: 0.02em;
  }

  .nr-more {
    margin-left: auto;
    font-size: 13px;
    color: rgba(17,17,17,.55);
    text-decoration: none;
    font-weight: 600;
  }
  .nr-more:hover { color: rgba(17,17,17,.85); }

  .nr-stage {
    position: relative;
    padding: 28px 16px 30px;
    overflow-x: auto;
    overflow-y: visible;
    border-top: 1px dashed rgba(17,17,17,.14);
    border-bottom: 1px dashed rgba(17,17,17,.14);
  }

  .nr-books {
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    gap: 3px;
    min-height: 200px;
    padding: 0 4px 14px;
  }

  .nr-book {
    --w: 32px;
    --h: 170px;
    position: relative;
    width: var(--w);
    height: var(--h);
    flex: 0 0 auto;
    text-decoration: none;
    transition: transform .25s cubic-bezier(.2,.7,.2,1);
    cursor: pointer;
  }

  .nr-book:hover {
    transform: translateY(-4px);
    z-index: 20;
  }

  .nr-book-spine {
    position: absolute;
    inset: 0;
    background: var(--spine);
    color: var(--ink);
    border-radius: 2px 3px 3px 2px;
    box-shadow:
      inset -2px 0 0 rgba(0,0,0,.18),
      inset 2px 0 0 rgba(255,255,255,.10),
      0 2px 4px rgba(0,0,0,.10);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding: 10px 3px 8px;
    overflow: hidden;
    background-image:
      linear-gradient(180deg, rgba(255,255,255,.04) 0%, transparent 30%, transparent 70%, rgba(0,0,0,.10) 100%),
      linear-gradient(90deg, rgba(0,0,0,.18) 0%, transparent 8%, transparent 92%, rgba(255,255,255,.06) 100%);
    transition: box-shadow .25s ease;
  }

  .nr-book:hover .nr-book-spine {
    box-shadow:
      inset -2px 0 0 rgba(0,0,0,.18),
      inset 2px 0 0 rgba(255,255,255,.10),
      0 6px 14px rgba(0,0,0,.16);
  }

  .nr-book-title {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-family: var(--serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: var(--ink);
    max-height: calc(var(--h) - 36px);
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 0 1px 0 rgba(0,0,0,.25);
  }

  .nr-book-init {
    font-family: var(--serif);
    font-size: 8px;
    letter-spacing: 0.06em;
    color: var(--ink);
    opacity: .82;
  }

  /* === Hover 弹出真实封面卡 === */
  .nr-book-card {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translate(-50%, 8px);
    margin-bottom: 10px;
    width: 150px;
    background: #fff;
    border-radius: 6px;
    box-shadow:
      0 14px 36px rgba(0,0,0,.22),
      0 4px 10px rgba(0,0,0,.12);
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity .22s ease,
      transform .28s cubic-bezier(.2,.7,.2,1),
      visibility 0s linear .22s;
    z-index: 30;
    overflow: hidden;
  }

  .nr-book:hover .nr-book-card {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
    transition:
      opacity .22s ease,
      transform .28s cubic-bezier(.2,.7,.2,1),
      visibility 0s linear 0s;
  }

  .nr-book-card img {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
  }

  .nr-card-placeholder {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 12px 10px;
    color: rgba(255,255,255,.95);
    width: 100%;
    aspect-ratio: 2 / 3;
    box-sizing: border-box;
    background-image:
      linear-gradient(180deg, rgba(255,255,255,.08) 0%, transparent 30%, transparent 70%, rgba(0,0,0,.20) 100%);
  }

  .nr-card-title {
    font-family: var(--serif);
    font-size: 12px;
    line-height: 1.25;
    font-weight: 700;
    text-shadow: 0 1px 0 rgba(0,0,0,.30);
  }
  .nr-card-author {
    margin-top: 4px;
    font-family: var(--sans);
    font-size: 9px;
    opacity: .88;
  }

  .nr-card-meta {
    display: block;
    padding: 9px 11px 11px;
    background: #fff;
  }
  .nr-card-name {
    display: block;
    font-family: var(--serif);
    font-size: 12px;
    font-weight: 700;
    color: rgba(17,17,17,.92);
    line-height: 1.3;
  }
  .nr-card-author-line {
    display: block;
    margin-top: 2px;
    font-family: var(--sans);
    font-size: 10px;
    color: rgba(17,17,17,.55);
  }
  .nr-card-keywords {
    display: block;
    margin-top: 6px;
    font-family: var(--serif);
    font-size: 11px;
    color: rgba(17,17,17,.62);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .nr-board {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 11px;
    background:
      linear-gradient(180deg, rgba(0,0,0,.10) 0%, rgba(0,0,0,0) 30%),
      repeating-linear-gradient(90deg,
        rgba(180,140,90,.18) 0,
        rgba(180,140,90,.18) 1px,
        transparent 1px,
        transparent 24px),
      linear-gradient(180deg, #d4b692 0%, #b89a76 100%);
    border-radius: 0 0 4px 4px;
    box-shadow:
      0 4px 10px rgba(120,90,50,.20),
      inset 0 -2px 0 rgba(0,0,0,.10);
  }
</style>