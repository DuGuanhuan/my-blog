---
import type { Book } from '../lib/notion';

interface Props {
  books: Book[];
}

const { books } = Astro.props;
if (!books || books.length === 0) return null;

function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}

// 给每本书生成一个稳定的颜色：基于 title hash 在调色板里取
const palette: { name: string; spine: string; ink: string }[] = [
  { name: 'orange-bright', spine: '#d96e2c', ink: 'rgba(255,255,255,.95)' },
  { name: 'navy',          spine: '#1f3a52', ink: 'rgba(255,255,255,.95)' },
  { name: 'ink',           spine: '#1a1a1a', ink: 'rgba(255,255,255,.92)' },
  { name: 'olive',         spine: '#8c9070', ink: 'rgba(255,255,255,.95)' },
  { name: 'brown',         spine: '#5a3e2e', ink: 'rgba(255,255,255,.95)' },
  { name: 'mustard',       spine: '#c89a14', ink: 'rgba(255,255,255,.95)' },
  { name: 'burgundy',      spine: '#5b2230', ink: 'rgba(255,255,255,.95)' },
  { name: 'sage',          spine: '#7a8a6f', ink: 'rgba(255,255,255,.95)' },
  { name: 'slate',         spine: '#5a6470', ink: 'rgba(255,255,255,.95)' },
  { name: 'sand',          spine: '#d4c5a3', ink: 'rgba(30,30,30,.78)' },
  { name: 'cream',         spine: '#ebe5d4', ink: 'rgba(30,30,30,.82)' },
  { name: 'rust',          spine: '#b95324', ink: 'rgba(255,255,255,.95)' },
  { name: 'forest',        spine: '#2d4a37', ink: 'rgba(255,255,255,.95)' },
  { name: 'plum',          spine: '#4f3047', ink: 'rgba(255,255,255,.95)' },
  { name: 'brick',         spine: '#a8452c', ink: 'rgba(255,255,255,.95)' },
];

function colorFor(b: Book) {
  const key = b.id + b.title;
  return palette[hashStr(key) % palette.length];
}

// 书脊标题：长标题截断成两行竖排
function spineTitle(t: string, max = 28): string {
  if (t.length <= max) return t;
  return t.slice(0, max - 1) + '…';
}

function spineAuthor(a: string | undefined, max = 18): string {
  if (!a) return '';
  return a.length <= max ? a : a.slice(0, max - 1) + '…';
}

function initials(b: Book): string {
  // 作者首字母缩写（最多 3 字符），放在书脊底部
  if (!b.author) return '';
  const cleaned = b.author.replace(/[《》()·•;，,.;:：]/g, ' ').trim();
  // 中文名：取最后 1-3 个字符
  const cn = cleaned.match(/[\u4e00-\u9fa5]{1,3}/g);
  if (cn && cn.length) return cn[cn.length - 1].slice(0, 3);
  // 英文名：取每个单词首字母
  const en = cleaned.split(/\s+/).filter(Boolean);
  if (en.length >= 2) return (en[0][0] + en[en.length - 1][0]).toUpperCase();
  return cleaned.slice(0, 3).toUpperCase();
}

// 显示多少本：默认 15 本，避免书架太长
const displayBooks = books.slice(0, 15);
---

<section id="bookshelf" class="bookshelf" aria-label="珍藏书架">
  <!-- 标题 + 编号标签 -->
  <div class="bookshelf-header">
    <div class="bookshelf-number" aria-hidden="true">
      <span class="num">04</span>
      <span class="hatch"></span>
    </div>
    <h2 class="bookshelf-title-h">珍藏书架</h2>
  </div>

  <!-- 书架本体 -->
  <div class="shelf-stage">
    <div class="shelf-books" role="list">
      {displayBooks.map((b) => {
        const c = colorFor(b);
        const author = spineAuthor(b.author);
        const title = spineTitle(b.title);
        const init = initials(b);
        return (
          <a
            class="book"
            href={b.url || '#'}
            role="listitem"
            title={`${b.title}${b.author ? ' — ' + b.author : ''}`}
            style={`--spine: ${c.spine}; --ink: ${c.ink};`}
          >
            <span class="book-spine">
              <span class="book-title-spine">{title}</span>
              {init && <span class="book-init">{init}</span>}
            </span>
            <span class="book-cover">
              {b.cover ? (
                <img src={b.cover} alt={b.title} loading="lazy" />
              ) : (
                <span class="book-cover-placeholder" style={`background: linear-gradient(135deg, ${c.spine}, color-mix(in srgb, ${c.spine} 65%, #000))`}>
                  <span class="book-cover-title">{b.title}</span>
                  {b.author && <span class="book-cover-author">{b.author}</span>}
                </span>
              )}
            </span>
          </a>
        );
      })}
    </div>
    <div class="shelf-board" aria-hidden="true"></div>
  </div>

  {books.length > displayBooks.length && (
    <p class="bookshelf-foot">共 {books.length} 本，这里展示最近 {displayBooks.length} 本</p>
  )}
</section>

<style>
  .bookshelf {
    margin-top: 56px;
    margin-bottom: 24px;
  }

  /* === 标题 + 编号标签 === */
  .bookshelf-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }

  .bookshelf-number {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--serif);
  }
  .bookshelf-number .num {
    font-size: 22px;
    font-weight: 700;
    color: rgba(17,17,17,.78);
    letter-spacing: 0.02em;
    border: 1px solid rgba(17,17,17,.18);
    padding: 2px 10px;
    border-radius: 4px;
    background: rgba(255,255,255,.55);
  }
  .bookshelf-number .hatch {
    display: inline-block;
    width: 22px;
    height: 18px;
    background-image:
      linear-gradient(135deg, transparent 33%, rgba(17,17,17,.18) 33%, rgba(17,17,17,.18) 38%, transparent 38%,
      transparent 60%, rgba(17,17,17,.18) 60%, rgba(17,17,17,.18) 65%, transparent 65%);
    border: 1px solid rgba(17,17,17,.18);
    border-radius: 3px;
  }

  .bookshelf-title-h {
    margin: 0;
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 700;
    color: rgba(17,17,17,.92);
    letter-spacing: 0.02em;
  }

  /* === 书架舞台 === */
  .shelf-stage {
    position: relative;
    padding: 28px 24px 30px;
    overflow-x: auto;
    overflow-y: visible;
    /* 边框虚线 cali 风格 */
    border-top: 1px dashed rgba(17,17,17,.14);
    border-bottom: 1px dashed rgba(17,17,17,.14);
    background:
      linear-gradient(180deg, rgba(255,255,255,.20) 0%, rgba(255,255,255,.0) 100%);
  }

  .shelf-books {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 4px;
    min-height: 280px;
    padding-bottom: 18px;
    /* 视口足够宽时铺满，窄时滚动 */
    perspective: 900px;
  }

  /* === 单本书 === */
  .book {
    --book-w: 38px;
    --book-h: 230px;
    position: relative;
    width: var(--book-w);
    height: var(--book-h);
    flex: 0 0 auto;
    text-decoration: none;
    transform-origin: bottom center;
    transition:
      transform .35s cubic-bezier(.2,.7,.2,1),
      filter .25s ease;
    transform-style: preserve-3d;
    cursor: pointer;
  }

  /* hover：往前拉出 + 整本书倾斜一点点 */
  .book:hover {
    transform: translateX(-12px) translateY(-2px) rotate(-3deg);
    z-index: 10;
    filter: drop-shadow(0 8px 16px rgba(0,0,0,.18));
  }

  /* 右边相邻的书稍微退让 */
  .book:hover + .book,
  .book:has(+ .book:hover) {
    transform: translateX(0);
  }

  /* === 书脊 === */
  .book-spine {
    position: absolute;
    inset: 0;
    background: var(--spine);
    color: var(--ink);
    border-radius: 2px 4px 4px 2px;
    box-shadow:
      inset -2px 0 0 rgba(0,0,0,.18),
      inset 2px 0 0 rgba(255,255,255,.10),
      0 2px 4px rgba(0,0,0,.10);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding: 14px 4px 10px;
    overflow: hidden;
    /* 轻微纹理 */
    background-image:
      linear-gradient(180deg, rgba(255,255,255,.04) 0%, transparent 30%, transparent 70%, rgba(0,0,0,.10) 100%),
      linear-gradient(90deg, rgba(0,0,0,.18) 0%, transparent 8%, transparent 92%, rgba(255,255,255,.06) 100%);
  }

  .book-title-spine {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-family: var(--serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: var(--ink);
    max-height: calc(var(--book-h) - 50px);
    overflow: hidden;
    text-overflow: ellipsis;
    /* 阴影增加立体感 */
    text-shadow: 0 1px 0 rgba(0,0,0,.25);
  }

  .book-init {
    font-family: var(--serif);
    font-size: 9px;
    letter-spacing: 0.06em;
    color: var(--ink);
    opacity: .82;
    /* 模拟作者缩写 */
  }

  /* === 封面（hover 时露出，靠背面对着观察者） === */
  .book-cover {
    position: absolute;
    inset: 0;
    background: #fff;
    border-radius: 2px;
    transform-origin: left center;
    transform: rotateY(-180deg) translateZ(1px);
    backface-visibility: hidden;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0,0,0,.12);
  }

  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 8px 6px;
    color: rgba(255,255,255,.92);
    box-sizing: border-box;
  }

  .book-cover-title {
    font-family: var(--serif);
    font-size: 10px;
    line-height: 1.2;
    font-weight: 700;
    text-shadow: 0 1px 0 rgba(0,0,0,.25);
  }

  .book-cover-author {
    margin-top: 4px;
    font-family: var(--sans);
    font-size: 7px;
    opacity: .85;
  }

  /* hover 时，把封面转出来 */
  .book:hover .book-cover {
    transform: rotateY(0deg) translateZ(1px);
  }

  /* 翻书的过渡更慢一点，更有"翻书"感 */
  .book-cover {
    transition: transform .45s cubic-bezier(.2,.7,.2,1);
  }

  /* === 木架子 === */
  .shelf-board {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 14px;
    /* 木纹：用三层叠加 */
    background:
      linear-gradient(180deg,
        rgba(0,0,0,.10) 0%,
        rgba(0,0,0,0) 30%),
      repeating-linear-gradient(90deg,
        rgba(180,140,90,.18) 0,
        rgba(180,140,90,.18) 1px,
        transparent 1px,
        transparent 24px),
      linear-gradient(180deg,
        #d4b692 0%,
        #b89a76 100%);
    border-radius: 0 0 4px 4px;
    box-shadow:
      0 4px 10px rgba(120,90,50,.20),
      inset 0 -2px 0 rgba(0,0,0,.10);
  }

  .shelf-stage {
    padding-bottom: 30px; /* 给木架子留位置 */
  }

  .bookshelf-foot {
    margin: 14px 0 0;
    text-align: center;
    font-size: 12px;
    color: rgba(17,17,17,.45);
    font-family: var(--serif);
  }
</style>