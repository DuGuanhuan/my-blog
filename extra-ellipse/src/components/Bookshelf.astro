---
import BookShelfRow from './BookShelfRow.astro';
import type { Book } from '../lib/notion';

interface Props {
  books: Book[];
}

const { books } = Astro.props;
if (!books?.length) return null;

const visibleBooks = books.slice(0, 84);
---

<section id="bookshelf" class="bookshelf" aria-labelledby="bookshelf-title">
  <header class="bookshelf__header">
    <div>
      <h2 id="bookshelf-title">珍藏书架</h2>
      <p>Books that shaped how I see the world.</p>
    </div>
  </header>

  <BookShelfRow
    books={visibleBooks}
    label="珍藏书架，横向浏览"
    initialIndex={0}
    explore
  />

  <p class="bookshelf__hint">滚轮、拖拽或方向键探索全部藏书</p>
  {books.length > visibleBooks.length && (
    <p class="bookshelf__count">共 {books.length} 本，这里展示最近 {visibleBooks.length} 本</p>
  )}
</section>

<style>
  .bookshelf {
    margin: 64px 0 28px;
  }

  .bookshelf__header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .bookshelf__header h2,
  .bookshelf__header p {
    margin: 0;
  }

  .bookshelf__header h2 {
    color: rgba(17, 17, 17, .76);
    font-family: var(--serif);
    font-size: clamp(21px, 2.7vw, 27px);
    font-weight: 500;
    letter-spacing: .04em;
  }

  .bookshelf__header p {
    margin-top: 3px;
    color: rgba(17, 17, 17, .38);
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: .04em;
  }

  .bookshelf__hint,
  .bookshelf__count {
    margin: 10px 0 0;
    color: rgba(17, 17, 17, .36);
    font-family: var(--sans);
    font-size: 11px;
    text-align: center;
  }

  .bookshelf__count {
    margin-top: 3px;
  }

  @media (max-width: 680px) {
    .bookshelf {
      width: calc(100% + 24px);
      margin-top: 52px;
      margin-left: -12px;
    }

    .bookshelf__header {
      padding: 0 12px;
    }

    .bookshelf__header p {
      display: none;
    }

    .bookshelf__hint {
      display: none;
    }
  }
</style>
