---
import Shell from '../components/Shell.astro';
import AlbumShelf from '../components/AlbumShelf.astro';
import NowReading from '../components/NowReading.astro';
import { listAlbums, listPosts, listCurrentlyReading } from '../lib/notion';

const posts = await listPosts({ includeDrafts: false });
const featured = posts.filter((p) => p.featured).slice(0, 5);
const latest = posts.slice(0, 6);

// Fetch currently reading books (gracefully handle empty)
let currentlyReading: Awaited<ReturnType<typeof listCurrentlyReading>> = [];
let albums: Awaited<ReturnType<typeof listAlbums>> = [];
try {
  currentlyReading = await listCurrentlyReading(6);
} catch {
  currentlyReading = [];
}
try {
  albums = await listAlbums();
} catch {
  albums = [];
}

function getTone(cat: string | undefined): string {
  if (!cat) return 'ink';
  const c = cat.toLowerCase();
  if (c.includes('agent') || c.includes('product')) return 'orange';
  if (c.includes('design') || c.includes('ux')) return 'magenta';
  if (c.includes('code') || c.includes('engineer')) return 'blue';
  return 'ink';
}

function fmtDate(iso?: string): string {
  if (!iso) return '';
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Shell
  title="Plan B Blog — Becoming in Public"
  description="记录成长、思考工具，以及真实生活的片刻。一个从 Notion 到 Astro 的公开蜕变实验场。"
>
  <!-- Hero -->
  <section class="hero content-wide">
    <div class="hero-grid">
      <div class="hero-left">
        <small>Becoming in Public</small>
        <p>
          <em>Write to become. Build to be free.</em>
        </p>
        <a class="btn primary" href="/blog">Browse posts</a>
      </div>

      <div class="hero-statement">
        <h1>Notes toward<br />a life of my own.</h1>
        <p class="hero-statement-copy">
          关于如何成长、如何思考，以及如何在既定路径之外，慢慢建立属于自己的生活。
        </p>
        <p class="hero-themes" aria-label="长期书写的四个主题">
          <span>Becoming</span>
          <span>Thinking Tools</span>
          <span>Lived Experience</span>
          <span>Quiet Essays</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Featured -->
  <section class="featured content-wide" aria-label="Featured">
    <div class="featured-grid">
      {(featured.length ? featured : latest.slice(0, 5)).map((p) => (
        <div class="feat">
          <h3><a href={`/blog/${p.slug}`} style="text-decoration:none;">{p.title}</a></h3>
          <p>{fmtDate(p.publishedAt)}</p>
        </div>
      ))}
    </div>
  </section>

  {albums.length > 0 && <div class="content-wide"><AlbumShelf albums={albums} /></div>}

  <!-- Now Reading -->
  {currentlyReading.length > 0 && <div class="content-wide"><NowReading books={currentlyReading} /></div>}

  <!-- Latest posts (static, no filtering) -->
  <section class="content-wide" style="padding: 44px 0;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:24px;">
      <h2 style="font-family: var(--serif); font-size: 24px; margin: 0; font-weight: 700;">最新文章</h2>
      <a href="/blog" style="font-size: 14px; color: rgba(17,17,17,.66); text-decoration: none; font-weight: 600;">查看全部 →</a>
    </div>

    <div class="grid">
      {latest.map((p) => {
        const tone = getTone(p.category);
        const hasImage = !!p.cover;
        const thumbStyle = hasImage ? `background-image: url('${p.cover}')` : '';
        return (
          <a class="card" href={`/blog/${p.slug}`} style="text-decoration:none; display:block; height:100%;">
            <div class={`thumb ${tone} ${hasImage ? 'has-image' : ''}`} style={thumbStyle} aria-hidden="true"></div>
            <div class="card-body">
              <div class="card-meta">
                <span>{fmtDate(p.publishedAt)}</span>
                <span class="chip">{p.category || 'Uncategorized'}</span>
              </div>
              <h3 class="card-title">{p.title}</h3>
              <p class="card-excerpt">{p.excerpt || ''}</p>
            </div>
          </a>
        );
      })}
    </div>

    <div class="home-more">
      <a href="/blog">浏览全部文章 →</a>
    </div>
  </section>
</Shell>
