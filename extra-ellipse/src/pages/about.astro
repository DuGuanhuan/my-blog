---
import Shell from '../components/Shell.astro';
import Bookshelf from '../components/Bookshelf.astro';
import { listBookshelf } from '../lib/notion';

let books: Awaited<ReturnType<typeof listBookshelf>> = [];
try {
  books = await listBookshelf();
} catch {
  books = [];
}
---

<Shell title="About" description="About this blog and the person behind it.">
  <section class="post about-page content-wide">
    <div class="about-copy content-reading">
      <h1>About</h1>
      <p class="about-lead">
        一个安静的角落，记录成长、思考工具，以及真实生活的片刻。
      </p>
      <p>
        Plan B 来自对既定路径的不满足：我想在主线之外，留下自己的思考，并慢慢建立另一种生活方式。
      </p>

      <div class="content about-content">
        <h2>Who I Am</h2>
        <p class="about-identity">本科动物学，硕士计算机，现在是一名互联网 B 端产品经理。</p>
        <p>
          我的成长路径经历过许多迷茫，也在一次次跨过外界与内心的困难后改变了身份。这里记录那些真实的挫折、选择与转变，写给仍在路上的人，也写给曾经的自己。
        </p>

        <h2>What I Write About</h2>
        <dl class="about-topics">
          <div>
            <dt>Becoming</dt>
            <dd>关于身份变化、能力边界和人生选择。</dd>
          </div>
          <div>
            <dt>Thinking Tools</dt>
            <dd>正在使用的方法论、思维模型与软件工具。</dd>
          </div>
          <div>
            <dt>Lived Experience</dt>
            <dd>低谷、高光，以及对真实世界的感受。</dd>
          </div>
          <div>
            <dt>Quiet Essays</dt>
            <dd>尚未形成结论的随笔、观察和想法。</dd>
          </div>
        </dl>

        <h2>Why This Blog Exists</h2>
        <p>
          这是一个 <strong>Becoming in Public（公开蜕变）</strong> 的实验场。我会如实记录问题、尝试与复盘，让成长轨迹可见、可追踪，也希望为正在经历相似旅程的人提供一些坐标。
        </p>

        <h2>Contact</h2>
        <p>若某篇文章与你产生共鸣，或想交流想法，可以通过以下方式找到我：</p>
        <ul class="about-links">
          <li><a href="https://github.com/DuGuanhuan" target="_blank" rel="noopener">GitHub <span aria-hidden="true">↗</span></a></li>
          <li><a href="/rss.xml">RSS <span aria-hidden="true">↗</span></a></li>
        </ul>
      </div>
    </div>

    <Bookshelf books={books} />
  </section>
</Shell>

<style>
  .about-copy h1 {
    margin-bottom: 12px;
  }

  .about-copy > p,
  .about-content > p {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.85;
  }

  .about-lead {
    margin-top: 0;
    color: rgba(17, 17, 17, .68);
  }

  .about-copy > p:not(.about-lead) {
    color: rgba(17, 17, 17, .72);
  }

  .about-content {
    margin-top: 28px;
  }

  .about-content h2 {
    margin-top: 1.85em;
  }

  .about-identity {
    color: rgba(17, 17, 17, .82);
    font-weight: 650;
  }

  .about-topics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 30px;
    margin: 8px 0 34px;
    border-top: 1px solid var(--line);
  }

  .about-topics > div {
    padding: 18px 0 17px;
    border-bottom: 1px solid var(--line);
  }

  .about-topics dt {
    color: rgba(17, 17, 17, .86);
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 700;
  }

  .about-topics dd {
    margin: 7px 0 0;
    color: rgba(17, 17, 17, .62);
    font-family: var(--serif);
    font-size: 14.5px;
    line-height: 1.7;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 16px 0;
    padding: 0;
    list-style: none;
  }

  .about-links a {
    color: rgba(17, 17, 17, .82);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 680px) {
    .about-copy > p,
    .about-content > p {
      font-size: 17px;
      line-height: 1.82;
    }

    .about-content h2 {
      margin-top: 1.65em;
    }

    .about-topics {
      grid-template-columns: 1fr;
      margin-bottom: 28px;
    }

    .about-topics > div {
      padding: 15px 0 14px;
    }
  }

</style>
