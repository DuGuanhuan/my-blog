---
import Shell from '../components/Shell.astro';
---

<Shell title="Subscribe" description="通过 RSS 订阅 Plan B Blog，获取新文章更新。">
  <section class="subscribe-page content-reading" aria-labelledby="subscribe-title">
    <p class="subscribe-kicker">Stay in touch</p>
    <h1 id="subscribe-title">Subscribe</h1>
    <p class="subscribe-intro">
      我更喜欢安静、不打扰的订阅方式。通过 RSS，你可以在自己的阅读器里收到每一篇新文章。
    </p>

    <div class="rss-panel">
      <svg class="rss-icon" aria-hidden="true" viewBox="0 0 24 24" width="26" height="26">
        <circle cx="5" cy="19" r="1.5"></circle>
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
      </svg>
      <div class="rss-copy">
        <h2>RSS Feed</h2>
        <p>适用于 NetNewsWire、Feedly、Inoreader 等 RSS 阅读器。</p>
        <code id="rssUrl">/rss.xml</code>
        <div class="rss-actions">
          <a href="/rss.xml">打开 RSS <span aria-hidden="true">↗</span></a>
          <button id="copyRss" type="button">复制地址</button>
        </div>
        <p class="copy-status" id="copyStatus" role="status" aria-live="polite"></p>
      </div>
    </div>

    <p class="subscribe-note">
      暂时不提供邮件订阅。等它真正可用、并且值得占用你的收件箱时，我会再把它放在这里。
    </p>
  </section>

  <script is:inline>
    (() => {
      const button = document.getElementById('copyRss');
      const status = document.getElementById('copyStatus');
      const display = document.getElementById('rssUrl');
      if (!button || !status || !display) return;

      const rssUrl = new URL('/rss.xml', window.location.origin).href;
      display.textContent = rssUrl;

      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(rssUrl);
          status.textContent = 'RSS 地址已复制';
          button.textContent = '已复制';
        } catch {
          status.textContent = '复制失败，请手动复制上方地址';
        }
      });
    })();
  </script>
</Shell>

<style>
  .subscribe-page {
    padding: 74px 0 92px;
  }

  .subscribe-kicker {
    margin: 0 0 12px;
    color: var(--soft);
    font-size: 12px;
    font-weight: 650;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .subscribe-page h1 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(42px, 7vw, 66px);
    line-height: 1;
    letter-spacing: -.035em;
  }

  .subscribe-intro {
    max-width: 32em;
    margin: 22px 0 42px;
    color: rgba(17, 17, 17, .72);
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.85;
  }

  .rss-panel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 20px;
    padding: 28px 0;
    border-top: 1px solid var(--line2);
    border-bottom: 1px solid var(--line2);
  }

  .rss-icon {
    margin-top: 3px;
    fill: none;
    stroke: rgba(17, 17, 17, .72);
    stroke-linecap: round;
    stroke-width: 1.6;
  }

  .rss-copy h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: 22px;
  }

  .rss-copy > p {
    margin: 8px 0 16px;
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.7;
  }

  .rss-copy code {
    display: block;
    overflow: hidden;
    color: rgba(17, 17, 17, .68);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rss-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 20px;
  }

  .rss-actions a,
  .rss-actions button {
    min-height: 40px;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgba(17, 17, 17, .82);
    cursor: pointer;
    font: inherit;
    font-size: 13px;
    font-weight: 650;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .copy-status {
    min-height: 1.5em;
    margin: 0 !important;
    color: var(--soft) !important;
    font-size: 12px !important;
  }

  .subscribe-note {
    max-width: 42em;
    margin: 28px 0 0;
    color: var(--soft);
    font-family: var(--serif);
    font-size: 14px;
    line-height: 1.8;
  }

  @media (max-width: 680px) {
    .subscribe-page {
      padding: 48px 0 70px;
    }

    .subscribe-intro {
      margin-bottom: 34px;
      font-size: 17px;
    }

    .rss-panel {
      gap: 16px;
      padding: 24px 0;
    }
  }
</style>
