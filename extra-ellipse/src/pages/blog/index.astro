---
import Shell from '../../components/Shell.astro';
import { listPosts } from '../../lib/notion';

const posts = await listPosts({ includeDrafts: false });
const primaryCategories = ['Becoming', 'Thinking Tools', 'Lived Experience', 'Quiet Essays'];
const categories = Array.from(new Set([
  ...primaryCategories,
  ...posts.map((post) => post.category).filter((category): category is string => Boolean(category)),
]));
const tags = Array.from(new Set(posts.flatMap((post) => post.tags || []))).sort();

const formatDate = (iso?: string) => {
  if (!iso) return '';
  return new Date(`${iso}T00:00:00`).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Shell
  title="Blog — Plan B"
  description="所有文章，涵盖 Becoming、Thinking Tools、Lived Experience 与 Quiet Essays 四个主题。"
>
  <section class="blog-index content-reading" aria-labelledby="blog-title">
    <header class="blog-heading">
      <p class="blog-kicker">Writing & notes</p>
      <h1 id="blog-title">Blog</h1>
      <p class="blog-intro">
        关于成长、思考工具与真实生活的记录。这里没有固定答案，只有持续发生的观察与修正。
      </p>
      <p class="blog-count"><span id="resultCount">{posts.length}</span> 篇文章</p>
    </header>

    <div class="blog-tools">
      <label class="blog-search" for="postSearch">
        <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
          <circle cx="11" cy="11" r="6.5"></circle>
          <path d="m16 16 4 4"></path>
        </svg>
        <span class="sr-only">搜索文章</span>
        <input id="postSearch" type="search" placeholder="搜索标题、摘要或标签" autocomplete="off" />
      </label>

      <details class="blog-filters" id="blogFilters">
        <summary>
          <span>筛选与排序</span>
          <span class="filter-state" id="filterState">全部文章</span>
          <svg aria-hidden="true" viewBox="0 0 20 20" width="16" height="16">
            <path d="m5 7.5 5 5 5-5"></path>
          </svg>
        </summary>
        <div class="filter-panel">
          <label>
            <span>分类</span>
            <select id="categoryFilter">
              <option value="">全部分类</option>
              {categories.map((category) => <option value={category}>{category}</option>)}
            </select>
          </label>
          <label>
            <span>标签</span>
            <select id="tagFilter">
              <option value="">全部标签</option>
              {tags.map((tag) => <option value={tag}>{tag}</option>)}
            </select>
          </label>
          <label>
            <span>排序</span>
            <select id="sortOrder">
              <option value="new">最新发布</option>
              <option value="old">最早发布</option>
            </select>
          </label>
          <button class="filter-clear" id="clearFilters" type="button">清除筛选</button>
        </div>
      </details>

      <nav class="blog-secondary-links" aria-label="更多文章浏览方式">
        <a href="/blog/tags">浏览标签 <span aria-hidden="true">↗</span></a>
        <a href="/blog/archive">文章归档 <span aria-hidden="true">↗</span></a>
      </nav>
    </div>

    <div class="post-list" id="postList" aria-live="polite">
      {posts.map((post) => (
        <article
          class:list={['post-list-item', { 'has-cover': Boolean(post.cover) }]}
          data-post
          data-date={post.publishedAt || ''}
          data-category={post.category || ''}
          data-tags={(post.tags || []).join('|')}
          data-search={[post.title, post.excerpt, post.category, ...(post.tags || [])].filter(Boolean).join(' ').toLowerCase()}
        >
          <a class="post-list-link" href={`/blog/${post.slug}`}>
            <div class="post-list-copy">
              <div class="post-list-meta">
                {post.publishedAt ? <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time> : null}
                {post.category ? <span>{post.category}</span> : null}
              </div>
              <h2>{post.title}</h2>
              {post.excerpt ? <p>{post.excerpt}</p> : null}
              {post.tags?.length ? (
                <ul class="post-list-tags" aria-label="文章标签">
                  {post.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
                </ul>
              ) : null}
            </div>
            {post.cover ? (
              <figure class="post-list-cover">
                <img src={post.cover} alt="" loading="lazy" decoding="async" />
              </figure>
            ) : null}
            <span class="post-list-arrow" aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>

    <div class="blog-empty" id="blogEmpty" hidden>
      <h2>没有找到相关文章</h2>
      <p>换一个关键词，或清除当前筛选条件。</p>
      <button class="filter-clear" id="clearFromEmpty" type="button">显示全部文章</button>
    </div>
  </section>

  <script is:inline>
    (() => {
      const search = document.getElementById('postSearch');
      const category = document.getElementById('categoryFilter');
      const tag = document.getElementById('tagFilter');
      const sort = document.getElementById('sortOrder');
      const list = document.getElementById('postList');
      const empty = document.getElementById('blogEmpty');
      const resultCount = document.getElementById('resultCount');
      const filterState = document.getElementById('filterState');
      const filters = document.getElementById('blogFilters');
      const clearButtons = [document.getElementById('clearFilters'), document.getElementById('clearFromEmpty')];
      const posts = Array.from(document.querySelectorAll('[data-post]'));

      if (!search || !category || !tag || !sort || !list || !empty || !resultCount || !filterState) return;

      const setSelectValue = (select, value, fallback = '') => {
        const exists = Array.from(select.options).some((option) => option.value === value);
        select.value = exists ? value : fallback;
      };

      const readUrlState = () => {
        const params = new URLSearchParams(window.location.search);
        search.value = params.get('q') || '';
        setSelectValue(category, params.get('category') || '');
        setSelectValue(tag, params.get('tag') || '');
        setSelectValue(sort, params.get('sort') || 'new', 'new');
        if (filters && (category.value || tag.value || sort.value === 'old')) filters.open = true;
      };

      const writeUrlState = () => {
        const params = new URLSearchParams();
        const query = search.value.trim();
        if (query) params.set('q', query);
        if (category.value) params.set('category', category.value);
        if (tag.value) params.set('tag', tag.value);
        if (sort.value === 'old') params.set('sort', 'old');

        const queryString = params.toString();
        const nextUrl = `${window.location.pathname}${queryString ? `?${queryString}` : ''}`;
        window.history.replaceState(null, '', nextUrl);
      };

      const render = ({ syncUrl = true } = {}) => {
        const query = search.value.trim().toLowerCase();
        const selectedCategory = category.value;
        const selectedTag = tag.value;
        const direction = sort.value === 'old' ? 1 : -1;

        const matched = posts.filter((post) => {
          const searchText = post.dataset.search || '';
          const postCategory = post.dataset.category || '';
          const postTags = (post.dataset.tags || '').split('|').filter(Boolean);
          return (!query || searchText.includes(query))
            && (!selectedCategory || postCategory === selectedCategory)
            && (!selectedTag || postTags.includes(selectedTag));
        });

        posts
          .sort((first, second) => (first.dataset.date || '').localeCompare(second.dataset.date || '') * direction)
          .forEach((post) => list.appendChild(post));

        posts.forEach((post) => {
          post.hidden = !matched.includes(post);
        });

        resultCount.textContent = String(matched.length);
        empty.hidden = matched.length > 0;

        const activeLabels = [selectedCategory, selectedTag].filter(Boolean);
        filterState.textContent = activeLabels.length ? activeLabels.join(' · ') : '全部文章';
        if (syncUrl) writeUrlState();
      };

      const clear = () => {
        search.value = '';
        category.value = '';
        tag.value = '';
        sort.value = 'new';
        render();
        search.focus();
      };

      search.addEventListener('input', render);
      category.addEventListener('change', render);
      tag.addEventListener('change', render);
      sort.addEventListener('change', render);
      clearButtons.forEach((button) => button?.addEventListener('click', clear));
      window.addEventListener('popstate', () => {
        readUrlState();
        render({ syncUrl: false });
      });

      readUrlState();
      render({ syncUrl: false });
    })();
  </script>
</Shell>

<style>
  .blog-index {
    padding: 68px 0 88px;
  }

  .blog-heading {
    max-width: 650px;
    margin-bottom: 42px;
  }

  .blog-kicker {
    margin: 0 0 12px;
    color: var(--soft);
    font-size: 12px;
    font-weight: 650;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .blog-heading h1 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(42px, 7vw, 68px);
    line-height: 1;
    letter-spacing: -.035em;
  }

  .blog-intro {
    max-width: 33em;
    margin: 20px 0 0;
    color: rgba(17, 17, 17, .7);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.8;
  }

  .blog-count {
    margin: 15px 0 0;
    color: var(--soft);
    font-size: 12.5px;
    font-variant-numeric: tabular-nums;
  }

  .blog-tools {
    margin-bottom: 18px;
    border-top: 1px solid var(--line2);
    border-bottom: 1px solid var(--line);
  }

  .blog-search {
    display: flex;
    min-height: 58px;
    align-items: center;
    gap: 12px;
  }

  .blog-search svg {
    flex: 0 0 auto;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.5;
    color: var(--soft);
  }

  .blog-search input {
    width: 100%;
    min-width: 0;
    padding: 15px 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-size: 15px;
  }

  .blog-search input::placeholder {
    color: rgba(17, 17, 17, .42);
  }

  .blog-filters {
    border-top: 1px solid var(--line);
  }

  .blog-filters summary {
    display: grid;
    min-height: 50px;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    color: rgba(17, 17, 17, .72);
    cursor: pointer;
    font-size: 13px;
    list-style: none;
  }

  .blog-filters summary::-webkit-details-marker {
    display: none;
  }

  .filter-state {
    overflow: hidden;
    color: var(--soft);
    text-align: right;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .blog-filters summary svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
    transition: transform .18s ease;
  }

  .blog-filters[open] summary svg {
    transform: rotate(180deg);
  }

  .filter-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr)) auto;
    gap: 12px;
    padding: 4px 0 18px;
  }

  .filter-panel label {
    display: grid;
    gap: 7px;
    color: var(--soft);
    font-size: 11px;
    letter-spacing: .03em;
  }

  .filter-panel select {
    min-width: 0;
    height: 40px;
    padding: 0 34px 0 11px;
    border: 1px solid var(--line2);
    border-radius: 8px;
    background-color: rgba(255, 255, 255, .46);
    color: rgba(17, 17, 17, .78);
    font: inherit;
    font-size: 13px;
  }

  .filter-clear {
    align-self: end;
    min-height: 40px;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgba(17, 17, 17, .58);
    cursor: pointer;
    font: inherit;
    font-size: 12.5px;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .blog-secondary-links {
    display: flex;
    gap: 22px;
    padding: 13px 0;
    border-top: 1px solid var(--line);
  }

  .blog-secondary-links a {
    color: rgba(17, 17, 17, .58);
    font-size: 12.5px;
    text-decoration: none;
  }

  .blog-secondary-links a:hover {
    color: var(--ink);
  }

  .post-list-item {
    border-bottom: 1px solid var(--line);
  }

  .post-list-item[hidden] {
    display: none;
  }

  .post-list-link {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    padding: 30px 34px 30px 0;
    text-decoration: none;
  }

  .post-list-link::before {
    position: absolute;
    inset: 8px -14px;
    z-index: -1;
    border-radius: 10px;
    background: rgba(255, 255, 255, .38);
    content: '';
    opacity: 0;
    transition: opacity .18s ease;
  }

  .post-list-link:hover::before,
  .post-list-link:focus-visible::before {
    opacity: 1;
  }

  .post-list-copy {
    min-width: 0;
  }

  .post-list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px 0;
    color: var(--soft);
    font-size: 12px;
  }

  .post-list-meta > * + *::before {
    display: inline-block;
    margin: 0 9px;
    content: '·';
    color: rgba(17, 17, 17, .3);
  }

  .post-list-copy h2 {
    margin: 10px 0 0;
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 29px);
    line-height: 1.3;
    letter-spacing: -.015em;
    text-wrap: balance;
  }

  .post-list-copy > p {
    display: -webkit-box;
    max-width: 48em;
    margin: 12px 0 0;
    overflow: hidden;
    color: rgba(17, 17, 17, .64);
    font-family: var(--serif);
    font-size: 14.5px;
    line-height: 1.75;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .post-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    margin: 14px 0 0;
    padding: 0;
    color: rgba(17, 17, 17, .45);
    font-size: 11.5px;
    list-style: none;
  }

  .post-list-tags li::before {
    content: '#';
  }

  .post-list-cover {
    width: 142px;
    aspect-ratio: 4 / 3;
    align-self: center;
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    background: var(--paper2);
  }

  .post-list-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .3s ease;
  }

  .post-list-link:hover .post-list-cover img {
    transform: scale(1.025);
  }

  .post-list-arrow {
    position: absolute;
    top: 30px;
    right: 0;
    color: rgba(17, 17, 17, .34);
    font-size: 14px;
    transition: color .18s ease, transform .18s ease;
  }

  .post-list-link:hover .post-list-arrow {
    color: var(--ink);
    transform: translate(2px, -2px);
  }

  .blog-empty {
    padding: 56px 0;
    text-align: center;
  }

  .blog-empty h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: 22px;
  }

  .blog-empty p {
    margin: 10px 0 16px;
    color: var(--muted);
    font-size: 13px;
  }

  @media (max-width: 680px) {
    .blog-index {
      padding: 44px 0 68px;
    }

    .blog-heading {
      margin-bottom: 32px;
    }

    .blog-intro {
      font-size: 16px;
    }

    .filter-panel {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .filter-clear {
      min-height: 36px;
      justify-self: start;
    }

    .post-list-link {
      display: block;
      padding: 26px 26px 26px 0;
    }

    .post-list-cover {
      width: 100%;
      margin-top: 18px;
      aspect-ratio: 16 / 9;
    }

    .post-list-copy h2 {
      font-size: 23px;
    }

    .post-list-copy > p {
      font-size: 14px;
    }

    .post-list-arrow {
      top: 27px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-filters summary svg,
    .post-list-link::before,
    .post-list-cover img,
    .post-list-arrow {
      transition: none;
    }
  }
</style>
